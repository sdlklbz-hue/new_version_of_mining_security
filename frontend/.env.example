# 复制为 .env.local 后按需填写（Vite 开发服务器启动时加载）
#
# 反向代理/隧道访问开发服务器时允许的 Host（逗号分隔，默认含 www.mon3tr.xin）
# VITE_DEV_ALLOWED_HOSTS=www.mon3tr.xin,mon3tr.xin,localhost
#
# 管理接口令牌：须与后端 MRA_ADMIN_TOKEN 保持一致。
# 若后端已设置 MRA_ALLOW_UNAUTHENTICATED_ADMIN=true（仅本地演示），此处可留空。
VITE_ADMIN_API_TOKEN=dev-admin-token

# 高德 3D 地图（可选，仅 3D 模式需要）
# VITE_AMAP_KEY=
# VITE_AMAP_SECURITY_CODE=
