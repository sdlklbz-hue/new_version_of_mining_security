# =============================================================================
# 一键部署可选环境变量（docker compose 会自动读取同目录 .env）
# 复制为 .env 后按需填写；缺省时后端将自动走 Mock 降级演示路径
# =============================================================================

# 当前 LLM provider。名称需对应 config.yaml 的 llm.providers.<provider>，
# 或通过前端“自定义模型”在运行时创建。
LLM_PROVIDER=glm5

# 当前 provider 的通用覆盖项（最高优先级，适合临时切换任意 OpenAI 兼容模型）
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# provider 专属覆盖项：LLM_<PROVIDER>_API_KEY / MODEL / BASE_URL
# 例如 provider=custom-openai 时，可使用 LLM_CUSTOM_OPENAI_API_KEY。

# 示例：智谱 GLM-5（OpenAI 兼容 SDK）
GLM5_API_KEY=
LLM_GLM5_MODEL=glm-5.1
LLM_GLM5_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 示例：DeepSeek（OpenAI 兼容 SDK）
DEEPSEEK_API_KEY=
LLM_DEEPSEEK_MODEL=deepseek-chat
LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com

# 备用：直接走 OpenAI 协议时的通用密钥
OPENAI_API_KEY=

# 管理接口保护：
# - LLM 配置、知识库写入、审计查询、模型迭代等敏感接口需要 X-Admin-Token。
# - 生产环境请设置强随机值，并通过受控客户端调用；不要把生产 Token 打进公开前端包。
# - 本地路演如确需无鉴权操作管理页，可临时设置 MRA_ALLOW_UNAUTHENTICATED_ADMIN=true。
MRA_ADMIN_TOKEN=
MRA_ALLOW_UNAUTHENTICATED_ADMIN=

# 决策工作流失败时是否允许返回 Mock 演示数据。
# 生产环境建议设为 false，使故障以 503 显式暴露。
MRA_ENABLE_MOCK_FALLBACK=true

# 完整决策结果 JSON 输出目录。必须位于服务端运行时 var 目录下。
# 可在前端「系统配置与 API」页运行时覆盖。
MINING_DECISION_OUTPUT_DIR=var/decisions

# CORS 白名单，逗号分隔。生产环境请改为真实前端 Origin。
MRA_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://localhost:5173,http://127.0.0.1:5173

# 前端高德 3D 地图（Vite 构建期注入；生产建议改为 Nginx 代理注入 jscode）
VITE_AMAP_KEY=
VITE_AMAP_SECURITY_CODE=

# 后端高德 Web 服务 Key：仅用于离线脚本抓取急救设施（运行时 API 读本地 JSON，不调用高德）。
# 需在高德控制台为该 Key 开通「Web 服务」；可与 VITE_AMAP_KEY 使用同一 Key（须同时勾选 JS API 与 Web 服务）。
# 一次性抓取：export MINING_PROJECT_ROOT="$(pwd)" && python scripts/fetch_emergency_facilities.py
# 默认输出 datasets/demo/emergency_facilities_suzhou.json；可用 EMERGENCY_FACILITIES_DATA_PATH 覆盖读取路径。
AMAP_WEB_SERVICE_KEY=
# 离线 POI 抓取请求间隔（秒），降低 infocode=10021 QPS 超限概率，默认 0.4
# AMAP_POI_REQUEST_INTERVAL_SEC=0.4
# EMERGENCY_FACILITIES_DATA_PATH=datasets/demo/emergency_facilities_suzhou.json

# 后端镜像依赖层选择：
# - requirements-deploy.txt：API + 当前模型推理依赖（Docker 默认）
# - requirements-deploy-rag.txt：API + 当前模型推理依赖 + RAG/长期记忆依赖
# - requirements.txt：仅 API 核心依赖，不能加载完整 Stacking pkl
# - requirements-full.txt：完整训练 / RAG / 旧 Streamlit / 测试依赖
API_REQUIREMENTS_FILE=requirements-deploy.txt

# -----------------------------------------------------------------------------
# RAG（检索增强生成）— 长期记忆召回、校验证据检索、决策工作流 memory_recall
# config.yaml 中 harness.memory.long_term.rag.enabled 默认为 true；
# 以下环境变量可覆盖（任一为 false/0/off 即关闭）。
# -----------------------------------------------------------------------------
RAG_ENABLED=true
# MINING_RAG_ENABLED=true
# HARNESS_RAG_ENABLED=true

# 嵌入后端：auto（优先 BGE，缺依赖时降级）| fallback | sentence_transformers
RAG_EMBEDDING_BACKEND=auto
# 允许 auto 模式在缺模型时降级为 deterministic fallback（离线/CI 推荐 true）
RAG_ALLOW_FALLBACK_EMBEDDING=true

# 校验层 EvidenceRetriever 单独指定嵌入后端（不设则与主 RAG 一致，见 RAG_EMBEDDING_BACKEND）
# 仅在校验层需与主路径刻意分离时设置，例如：VALIDATION_RAG_EMBEDDING_BACKEND=fallback

# 向量库路径与集合名（默认与 config.yaml 一致，一般无需改）
# RAG_PERSIST_DIRECTORY=var/chroma
# RAG_COLLECTION_NAME=knowledge_base

# BGE 模型默认缓存：~/.cache/huggingface/hub/（首次 auto/sentence_transformers 会下载，见 README §4）
# HF_HOME=/path/to/huggingface
# HUGGINGFACE_HUB_CACHE=/path/to/huggingface/hub
