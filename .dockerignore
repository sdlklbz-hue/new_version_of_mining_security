# 后端镜像构建上下文：mining_risk_agent/
# 排除前端工程、缓存、IDE 等无关内容，加快镜像构建
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.coverage
htmlcov
.mypy_cache

# 本地环境变量与密钥
.env
.env.*
!.env.example

# 前端 SPA 工程对后端镜像无意义
frontend/
!frontend/.gitkeep

# Catboost 训练中间产物
catboost_info

# IDE / 系统
.vscode
.devcontainer
.git
.github
.DS_Store

# 模型与日志（容器内由 volume 提供）
logs/*.log
